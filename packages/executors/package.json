{
  "name": "@agent-foundry/executors",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:index && npm run build:sidecar",
    "build:index": "tsup src/index.ts --format esm --clean --sourcemap",
    "build:sidecar": "esbuild src/docker-network-policy-sidecar.ts --bundle --platform=node --format=esm --target=node22 --packages=bundle --outfile=dist/docker-network-policy-sidecar.js --sourcemap",
    "typecheck": "tsc --noEmit"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@agent-foundry/contracts": "0.1.0",
    "@agent-foundry/domain": "0.1.0",
    "@opentelemetry/api": "^1.9.1",
    "execa": "^10.0.0",
    "playwright": "^1.61.1"
  }
}
