# Shared runtime
NODE_ENV=development
DATA_DIR=./data
HARNESS_DIR=./harness
WORKFLOWS_DIR=./workflows
MODEL_CATALOG_PATH=./models/catalog.yaml
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
LOG_LEVEL=info

# Run the worker in the API process for the simplest local setup.
RUN_WORKER_INLINE=false
WORKER_POLL_INTERVAL_MS=750
WORKER_ID=local-worker

# real | mock. Mock mode lets you exercise the entire pipeline without any CLI installed.
EXECUTOR_MODE=mock
AGENT_TIMEOUT_MS=1200000
MAX_CLI_OUTPUT_BYTES=10485760

# Safety and verification
AUTO_INSTALL_DEPENDENCIES=false
VERIFICATION_TIMEOUT_MS=600000
GIT_AUTHOR_NAME=Agent Foundry
GIT_AUTHOR_EMAIL=agent-foundry@localhost

# Optional model overrides. Empty means: let the CLI use its configured default.
CODEX_DEFAULT_MODEL=
CODEX_FAST_MODEL=
CLAUDE_DEEP_MODEL=opus
CLAUDE_BALANCED_MODEL=sonnet
CLAUDE_FAST_MODEL=haiku
AGY_DEFAULT_MODEL=
AGY_FAST_MODEL=
AGY_DEEP_MODEL=

# Set true only after filling the corresponding model name above.
ENABLE_CODEX_FAST=false
ENABLE_AGY_FAST=false
ENABLE_AGY_DEEP=false
