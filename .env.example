# Shared runtime
NODE_ENV=development
DATA_DIR=./data
HARNESS_DIR=./harness
WORKFLOWS_DIR=./workflows
POLICIES_DIR=./policies
MODEL_CATALOG_PATH=./models/catalog.yaml
API_HOST=127.0.0.1
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
LOG_LEVEL=info

# Run the worker in the API process for the simplest local setup.
RUN_WORKER_INLINE=false
WORKER_POLL_INTERVAL_MS=750
WORKER_ID=local-worker
# How often a running orchestration checks for a persisted cancel request.
CANCEL_POLL_INTERVAL_MS=500

# Queue lease: how long a claim is valid without a heartbeat, how often the
# worker renews it, and how often the reaper looks for expired leases.
QUEUE_LEASE_MS=60000
QUEUE_HEARTBEAT_INTERVAL_MS=15000
QUEUE_REAP_INTERVAL_MS=20000

# real | mock. Mock mode lets you exercise the entire pipeline without any CLI installed.
EXECUTOR_MODE=mock

# Deployment Profile: development | real-local-trusted | mock-production
# development: mock execution on loopback
# real-local-trusted: real execution on loopback only (max before v0.4.5)
# mock-production: mock execution on all interfaces (production-safe)

AGENT_TIMEOUT_MS=1200000
MAX_CLI_OUTPUT_BYTES=10485760

# Safety and verification
# Fail-closed: real CLI execution cannot bind to a non-loopback host unless this is explicitly true.
ALLOW_UNSAFE_REMOTE_REAL_EXECUTION=false
AUTO_INSTALL_DEPENDENCIES=false
VERIFICATION_TIMEOUT_MS=600000
GIT_AUTHOR_NAME=Agent Foundry
GIT_AUTHOR_EMAIL=agent-foundry@localhost

# Optional model overrides. Empty means: let the CLI use its configured default.
CODEX_DEFAULT_MODEL=
CODEX_FAST_MODEL=
CLAUDE_DEEP_MODEL=opus
CLAUDE_BALANCED_MODEL=sonnet
CLAUDE_FAST_MODEL=haiku
AGY_DEFAULT_MODEL=
AGY_FAST_MODEL=
AGY_DEEP_MODEL=

# Set true only after filling the corresponding model name above.
ENABLE_CODEX_FAST=false
ENABLE_AGY_FAST=false
ENABLE_AGY_DEEP=false

# Real-provider canaries are fail-closed and never invoke a provider unless this is true.
RUN_REAL_PROVIDER_CANARIES=false
CODEX_CANARY_MODEL=gpt-5.6-sol
CLAUDE_CANARY_MODEL=sonnet
AGY_CANARY_MODEL=Gemini 3.1 Pro (Low)

# Real dogfood runs (npm run dogfood:run) are fail-closed and never invoke a provider unless this is true.
RUN_REAL_DOGFOOD=false

# Blob storage: fs | s3. fs stores bytes under DATA_DIR and works out of the
# box — a per-installation signing secret is auto-generated at
# DATA_DIR/blob-signing-secret the first time it's needed. Set BLOB_SIGNING_SECRET
# explicitly to pin it (e.g. across a migration), or switch to s3 for an
# S3-compatible store (AWS S3, MinIO, ...).
BLOB_STORE_MODE=fs
# BLOB_SIGNING_SECRET=
# How long an unreferenced blob (revision allocated, bytes uploaded, but no
# artifact metadata pointing at it yet) is kept before the reaper deletes it.
BLOB_GC_GRACE_MS=86400000

# Required when BLOB_STORE_MODE=s3. Below: MinIO (local/CI fallback) example values.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=agent-foundry
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true

# Supabase Storage (hosted, docs/OPERATIONS.md#supabase-storage-hospedado-recomendado):
# same S3_* shape, pointed at your project's storage endpoint instead.
# S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
# S3_REGION=<from the S3 Connection page in Project Settings > Storage>
# S3_BUCKET=<bucket you created in the Supabase dashboard>
# S3_ACCESS_KEY_ID=<from the S3 Connection page>
# S3_SECRET_ACCESS_KEY=<from the S3 Connection page>
# S3_FORCE_PATH_STYLE=true
# Local dev via `supabase start` instead: S3_ENDPOINT=http://127.0.0.1:54321/storage/v1/s3, S3_REGION=local
