+  NPM_CONFIG_REGISTRY: https://registry.npmjs.org/
 
 jobs:
+  preflight:
+    name: preflight
+    runs-on: ubuntu-latest
+    timeout-minutes: 5
+    steps:
+      - uses: actions/checkout@v7
+      - name: Reject private registry URLs in package-lock.json
+        run: |
+          if grep -nE 'applied-caas-gateway|internal\.api\.openai\.org|artifactory/api/npm/npm-public' package-lock.json; then
+            echo '::error::package-lock.json contains a private registry URL. Regenerate or normalize the lockfile before running CI.'
+            exit 1
+          fi
+
