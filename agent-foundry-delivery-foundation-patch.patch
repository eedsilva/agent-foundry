+++ b/planning/governance-spec.json
@@ -0,0 +1,49 @@
+{
+  "schemaVersion": "1.0.0",
+  "repository": "eedsilva/agent-foundry",
+  "ruleset": {
+    "name": "Agent Foundry main protection",
+    "target": "branch",
+    "enforcement": "active",
+    "include": ["~DEFAULT_BRANCH"],
+    "requiredStatusChecks": [
+      "format",
+      "lint",
+      "architecture",
+      "roadmap",
+      "typecheck",
+      "test",
+      "build",
+      "dependency-review"
+    ],
+    "pullRequest": {
+      "requiredApprovingReviewCount": 0,
+      "dismissStaleReviewsOnPush": false,
+      "requireCodeOwnerReview": false,
+      "requireLastPushApproval": false,
+      "requiredReviewThreadResolution": true,
+      "allowedMergeMethods": ["squash", "rebase"]
+    },
+    "requiredLinearHistory": true,
+    "blockDeletion": true,
+    "blockForcePush": true
+  },
+  "release": {
+    "tag": "v0.1.0",
+    "name": "Agent Foundry v0.1.0 baseline",
+    "bodyPath": "docs/releases/v0.1.0.md",
+    "prerelease": true,
+    "draft": false,
+    "target": "92b071ceb3365cb74d954cc67c496e3e5ecc9e6a"
+  },
+  "repositorySettings": {
+    "allowSquashMerge": true,
+    "allowRebaseMerge": true,
+    "allowMergeCommit": false,
+    "deleteBranchOnMerge": true
+  },
+  "security": {
+    "enableVulnerabilityAlerts": true,
+    "enableAutomatedSecurityFixes": true
+  }
+}
diff --git a/planning/project-spec.json b/planning/project-spec.json
new file mode 100644
index 0000000..676a865
--- /dev/null
+++ b/planning/project-spec.json
@@ -0,0 +1,303 @@
+{
+  "schemaVersion": "1.0.0",
+  "repository": "eedsilva/agent-foundry",
+  "owner": "eedsilva",
+  "title": "Agent Foundry Delivery",
+  "shortDescription": "Execution board for the Personal Builder v1 and Hosted Platform v2 tracks.",
+  "readme": "# Agent Foundry Delivery\n\nGenerated from `planning/roadmap-spec.json`. Milestones answer which release owns an item. Project fields answer what is active, risky, blocked, or supported by evidence.\n\n## Operating rules\n\n- Maximum two items in **In Progress**.\n- **P0** means an active release blocker or critical safety/data risk.\n- An item moves to **Done** only after the repository Definition of Done is satisfied.\n- Hosted v2 work does not block Personal Builder v1 unless an explicit dependency says so.\n",
+  "public": true,
+  "fields": [
+    {
+      "name": "Status",
+      "type": "SINGLE_SELECT",
+      "options": [
+        {
+          "name": "Inbox",
+          "color": "GRAY",
+          "description": "Not triaged"
+        },
+        {
+          "name": "Ready",
+          "color": "BLUE",
+          "description": "Ready to start"
+        },
+        {
+          "name": "In Progress",
+          "color": "YELLOW",
+          "description": "Actively being implemented; WIP limit 2"
+        },
+        {
+          "name": "In Review",
+          "color": "PURPLE",
+          "description": "Pull request or human review in progress"
+        },
+        {
+          "name": "Blocked",
+          "color": "RED",
+          "description": "Cannot advance without a named unblocker"
+        },
+        {
+          "name": "Done",
+          "color": "GREEN",
+          "description": "Definition of Done and evidence satisfied"
+        }
+      ]
+    },
+    {
+      "name": "Commitment",
+      "type": "SINGLE_SELECT",
+      "options": [
+        {
+          "name": "Now",
+          "color": "RED",
+          "description": "Active commitment"
+        },
+        {
+          "name": "Next",
+          "color": "YELLOW",
+          "description": "Next after active work"
+        },
+        {
+          "name": "Candidate",
+          "color": "BLUE",
+          "description": "Candidate scope, subject to evidence"
+        },
+        {
+          "name": "Exploratory",
+          "color": "GRAY",
+          "description": "Future hypothesis, not a commitment"
+        }
+      ]
+    },
+    {
+      "name": "Size",
+      "type": "SINGLE_SELECT",
+      "options": [
+        {
+          "name": "XS",
+          "color": "GRAY",
+          "description": "Hours"
+        },
+        {
+          "name": "S",
+          "color": "GREEN",
+          "description": "Up to roughly one focused day"
+        },
+        {
+          "name": "M",
+          "color": "BLUE",
+          "description": "Several focused days"
+        },
+        {
+          "name": "L",
+          "color": "YELLOW",
+          "description": "Needs decomposition before commitment"
+        },
+        {
+          "name": "XL",
+          "color": "RED",
+          "description": "Must be decomposed before Ready"
+        }
+      ]
+    },
+    {
+      "name": "Risk",
+      "type": "SINGLE_SELECT",
+      "options": [
+        {
+          "name": "Low",
+          "color": "GREEN",
+          "description": "Contained and reversible"
+        },
+        {
+          "name": "Medium",
+          "color": "BLUE",
+          "description": "Meaningful trade-offs or migration"
+        },
+        {
+          "name": "High",
+          "color": "YELLOW",
+          "description": "Cross-cutting, irreversible, or operationally risky"
+        },
+        {
+          "name": "Critical",
+          "color": "RED",
+          "description": "Security, data, isolation, or launch-critical risk"
+        }
+      ]
+    },
+    {
+      "name": "Confidence",
+      "type": "SINGLE_SELECT",
+      "options": [
+        {
+          "name": "Low",
+          "color": "RED",
+          "description": "Assumptions dominate evidence"
+        },
+        {
+          "name": "Medium",
+          "color": "YELLOW",
+          "description": "Some evidence; material uncertainty remains"
+        },
+        {
+          "name": "High",
+          "color": "GREEN",
+          "description": "Validated by tests, experiments, or production evidence"
+        }
+      ]
+    },
+    {
+      "name": "Track",
+      "type": "SINGLE_SELECT",
+      "options": [
+        {
+          "name": "Core",
+          "color": "BLUE",
+          "description": "Workflow engine and delivery fundamentals"
+        },
+        {
+          "name": "UX",
+          "color": "PINK",
+          "description": "Builder, conversation, preview, and visual editing"
+        },
+        {
